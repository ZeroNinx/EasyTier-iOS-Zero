#!/bin/sh
set -e

BASE="/var/jb/var/lib/easytier"
PLIST="/var/jb/Library/LaunchDaemons/com.zeroninex.easytierd.plist"
LABEL="com.zeroninex.easytierd"
JOB="system/$LABEL"
LEGACY_LABEL="com.zeroninx.easytierd"
LEGACY_JOB="system/$LEGACY_LABEL"
LEGACY_PLIST="/var/jb/Library/LaunchDaemons/$LEGACY_LABEL.plist"
MOBILE_IDENTIFIERS="com.zeroninex.easytier com.zeroninx.easytier group.com.zeroninex.easytier group.com.zeroninx.easytier"
APP="/var/jb/Applications/EasyTier.app"
PKG_LOG="$BASE/logs/package.log"

mkdir -p "$BASE/profiles" "$BASE/logs" "$BASE/runtime" "$BASE/exports"
chown -R root:wheel "$BASE" 2>/dev/null || true
chmod 700 "$BASE" "$BASE/profiles" "$BASE/logs" "$BASE/runtime" "$BASE/exports"

log() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') postinst: $*" >> "$PKG_LOG"
}

run_logged() {
    log "$*"
    "$@" >> "$PKG_LOG" 2>&1 || log "failed: $*"
}

find_cmd() {
    for candidate in "$@"; do
        if [ -x "$candidate" ]; then
            echo "$candidate"
            return 0
        fi
    done
    return 1
}

stop_daemon() {
    LAUNCHCTL="$(find_cmd /bin/launchctl /var/jb/bin/launchctl || true)"
    KILLALL="$(find_cmd /usr/bin/killall /var/jb/usr/bin/killall || true)"

    if [ -n "$LAUNCHCTL" ]; then
        run_logged "$LAUNCHCTL" bootout "$JOB"
        run_logged "$LAUNCHCTL" bootout system "$PLIST"
    fi

    if [ -n "$KILLALL" ]; then
        run_logged "$KILLALL" easytierd
        sleep 1
        run_logged "$KILLALL" -9 easytierd
    fi
}

plist_contains_identifier() {
    plist="$1"
    identifier="$2"

    if command -v plutil >/dev/null 2>&1 && plutil -p "$plist" 2>/dev/null | grep -Fq "\"$identifier\""; then
        return 0
    fi

    if command -v strings >/dev/null 2>&1 && strings "$plist" 2>/dev/null | grep -qx "$identifier"; then
        return 0
    fi

    return 1
}

remove_mobile_app_bundles_for_identifier() {
    identifier="$1"

    for app in /var/mobile/Containers/Bundle/Application/*/*.app; do
        [ -d "$app" ] || continue
        info="$app/Info.plist"
        [ -f "$info" ] || continue
        if plist_contains_identifier "$info" "$identifier"; then
            run_logged rm -rf "$(dirname "$app")"
        fi
    done
}

cleanup_legacy_install() {
    LAUNCHCTL="$(find_cmd /bin/launchctl /var/jb/bin/launchctl || true)"
    if [ -n "$LAUNCHCTL" ]; then
        run_logged "$LAUNCHCTL" bootout "$LEGACY_JOB"
        if [ -f "$LEGACY_PLIST" ]; then
            run_logged "$LAUNCHCTL" bootout system "$LEGACY_PLIST"
        fi
    fi

    if [ -f "$LEGACY_PLIST" ]; then
        run_logged rm -f "$LEGACY_PLIST"
    fi

    for identifier in $MOBILE_IDENTIFIERS; do
        remove_mobile_app_bundles_for_identifier "$identifier"
        if [ -x /usr/bin/uicache ]; then
            run_logged /usr/bin/uicache -u "$identifier"
        elif [ -x /var/jb/usr/bin/uicache ]; then
            run_logged /var/jb/usr/bin/uicache -u "$identifier"
        fi
    done
}

start_daemon() {
    LAUNCHCTL="$(find_cmd /bin/launchctl /var/jb/bin/launchctl || true)"
    if [ -z "$LAUNCHCTL" ] || [ ! -f "$PLIST" ]; then
        log "launchctl or plist unavailable, daemon not started"
        return 0
    fi

    log "$LAUNCHCTL bootstrap system $PLIST"
    if "$LAUNCHCTL" bootstrap system "$PLIST" >> "$PKG_LOG" 2>&1; then
        log "bootstrap succeeded"
    else
        log "bootstrap failed, retrying after bootout"
        run_logged "$LAUNCHCTL" bootout "$JOB"
        run_logged "$LAUNCHCTL" bootout system "$PLIST"
        sleep 1
        run_logged "$LAUNCHCTL" bootstrap system "$PLIST"
    fi

    run_logged "$LAUNCHCTL" enable "$JOB"
    run_logged "$LAUNCHCTL" kickstart -k "$JOB"
    run_logged "$LAUNCHCTL" print "$JOB"
}

log "starting"

cleanup_legacy_install

if [ -x /usr/bin/uicache ]; then
    run_logged /usr/bin/uicache -p "$APP"
elif [ -x /var/jb/usr/bin/uicache ]; then
    run_logged /var/jb/usr/bin/uicache -p "$APP"
fi

stop_daemon
start_daemon

log "finished"

exit 0
