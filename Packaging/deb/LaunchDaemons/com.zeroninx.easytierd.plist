<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.zeroninx.easytierd</string>
    <key>ProgramArguments</key>
    <array>
        <string>/var/jb/usr/bin/easytierd</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/var/mobile/Library/Application Support/EasyTier/logs/easytierd.stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/var/mobile/Library/Application Support/EasyTier/logs/easytierd.stderr.log</string>
</dict>
</plist>
